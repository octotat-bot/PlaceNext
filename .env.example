# Environment Configuration Template
# Copy this file to .env and update the values

# ===========================================
# REQUIRED - Change these in production!
# ===========================================

# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your-secure-mongo-password

# JWT Secret (minimum 32 characters, random string)
JWT_SECRET=your-super-secure-random-jwt-secret-minimum-32-chars

# ===========================================
# EMAIL CONFIGURATION (Required for production)
# ===========================================

# SMTP Settings (e.g., Gmail, SendGrid, Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM="Placement Portal" <noreply@placementportal.edu>

# ===========================================
# OPTIONAL - Defaults are fine for development
# ===========================================

# Frontend URL (for email links)
FRONTEND_URL=http://localhost

# Node environment
NODE_ENV=production

# ===========================================
# ADMIN SEEDING (First-time setup)
# ===========================================

SEED_ADMIN_EMAIL=admin@placementcell.edu
SEED_ADMIN_PASSWORD=Admin@123!
SEED_ADMIN_NAME=Super Admin
